{
  "datasets": [
    {
      "name": "cdeb996c",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `salesdb`;\n",
        "\n",
        "SHOW TABLES; \n",
        "\n",
        "DESCRIBE TABLE dim_customers;\n",
        "DESCRIBE TABLE workspace.salesdb.dim_products; \n",
        "\n",
        "SELECT DISTINCT country FROM dim_customers; \n",
        "\n",
        "SELECT product_name, category, subcategory FROM dim_products;\n",
        "\n",
        "--Total Sales\n",
        "SELECT SUM(sales_amount) AS Total_Sales FROM fact_sales;\n",
        "\n",
        "-- Total Customers\n",
        "SELECT COUNT(DISTINCT customer_id) AS total_customers FROM dim_customers; \n",
        "\n",
        "--Total Orders\n",
        "SELECT COUNT(DISTINCT order_number) AS total_orders FROM fact_sales; \n",
        "\n",
        "--Sales by Product\n",
        "SELECT c.product_name, SUM(f.sales_amount) FROM dim_products c LEFT JOIN fact_sales f ON c.product_key = f.product_key GROUP BY c.product_name ORDER BY SUM(f.sales_amount) DESC; \n",
        "\n",
        "--Sales by Category\n",
        "SELECT c.category, SUM(f.sales_amount) FROM\n",
        "dim_products c LEFT JOIN fact_sales f ON c.product_key = f.product_key GROUP BY c.category ORDER BY SUM(f.sales_amount) DESC; \n",
        "\n",
        "-- Orders Over Time\n",
        "SELECT date_trunc('month',order_date), SUM(sales_amount) FROM fact_sales GROUP BY date_trunc('month',order_date);"
      ]
    },
