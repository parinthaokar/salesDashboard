    {
      "name": "f0c68ecb",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `salesdb`;\n",
        "\n",
        "SELECT c.customer_id, AVG(f.sales_amount) \n",
        "FROM workspace.salesdb.dim_customers c LEFT JOIN workspace.salesdb.fact_sales f ON c.customer_key = f.customer_key\n",
        "GROUP BY c.customer_id; "
      ]
    },
    {
      "name": "01daaae3",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `salesdb`;\n",
        "\n",
        "SELECT c.customer_id, SUM(f.sales_amount) \n",
        "FROM workspace.salesdb.dim_customers c LEFT JOIN workspace.salesdb.fact_sales f ON c.customer_key = f.customer_key\n",
        "GROUP BY c.customer_id\n",
        "ORDER BY SUM(f.sales_amount) DESC\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "0b87ace8",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `salesdb`;\n",
        "\n",
        "WITH customer_ages AS (\n",
        "  SELECT \n",
        "    f.order_number,\n",
        "    YEAR(CURRENT_DATE()) - YEAR(c.birthdate) AS age\n",
        "  FROM workspace.salesdb.fact_sales f\n",
        "  JOIN workspace.salesdb.dim_customers c ON f.customer_key = c.customer_key\n",
        "  WHERE c.birthdate IS NOT NULL\n",
        ")\n",
        "SELECT \n",
        "  CASE \n",
        "    WHEN age BETWEEN 18 AND 25 THEN '18-25'\n",
        "    WHEN age BETWEEN 26 AND 35 THEN '26-35'\n",
        "    WHEN age BETWEEN 36 AND 45 THEN '36-45'\n",
        "    WHEN age BETWEEN 46 AND 55 THEN '46-55'\n",
        "    WHEN age > 55 THEN '56+'\n",
        "    ELSE 'Under 18'\n",
        "  END AS age_group,\n",
        "  COUNT(DISTINCT order_number) AS number_of_orders\n",
        "FROM customer_ages\n",
        "GROUP BY age_group\n",
        "ORDER BY \n",
        "  CASE age_group\n",
        "    WHEN 'Under 18' THEN 1\n",
        "    WHEN '18-25' THEN 2\n",
        "    WHEN '26-35' THEN 3\n",
        "    WHEN '36-45' THEN 4\n",
        "    WHEN '46-55' THEN 5\n",
        "    WHEN '56+' THEN 6\n",
        "  END"
      ]
    }
  ],
