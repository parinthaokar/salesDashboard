       "command": "%sql WITH q AS (SELECT c.customer_id, AVG(f.sales_amount) \nFROM workspace.salesdb.dim_customers c LEFT JOIN workspace.salesdb.fact_sales f ON c.customer_key = f.customer_key\nGROUP BY c.customer_id) ,min_max AS (SELECT `avg(sales_amount)`,(SELECT MAX(`avg(sales_amount)`) FROM q) `target_column_max`,(SELECT MIN(`avg(sales_amount)`) FROM q) `target_column_min` FROM q) ,histogram_meta AS (SELECT `avg(sales_amount)`,`target_column_min` `min_value`,IF(`target_column_max` = `target_column_min`,`target_column_max` + 1,`target_column_max`) `max_value`,(`target_column_max` - `target_column_min`) / 5 `step` FROM min_max) SELECT IF(ISNULL(`avg(sales_amount)`),NULL,LEAST(WIDTH_BUCKET(`avg(sales_amount)`,`min_value`,`max_value`,5),5)) `avg(sales_amount)_BIN`,FIRST(`min_value` + ((IF(ISNULL(`avg(sales_amount)`),NULL,LEAST(WIDTH_BUCKET(`avg(sales_amount)`,`min_value`,`max_value`,5),5)) - 1) * `step`)) `avg(sales_amount)_BIN_LOWER_BOUND`,FIRST(`step`) `avg(sales_amount)_BIN_STEP`,COUNT(`avg(sales_amount)`) `COUNT` FROM histogram_meta GROUP BY `avg(sales_amount)_BIN`",
